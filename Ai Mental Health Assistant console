# MARKOV EMOTION FORECAST
# ==========================================================

transition_matrix = {

    "Calm": {
        "Calm": 0.6,
        "Stress": 0.2,
        "Sad": 0.1,
        "Anxiety": 0.1
    },

    "Stress": {
        "Calm": 0.2,
        "Stress": 0.5,
        "Sad": 0.2,
        "Anxiety": 0.1
    },

    "Sad": {
        "Calm": 0.3,
        "Stress": 0.3,
        "Sad": 0.3,
        "Anxiety": 0.1
    },

    "Anxiety": {
        "Calm": 0.2,
        "Stress": 0.4,
        "Sad": 0.2,
        "Anxiety": 0.2
    }
}

def markov_forecast():

    print("\n==============================")
    print(" MARKOV EMOTIONAL FORECAST ")
    print("==============================")

    current = input("Current Emotion: ")

    if current not in transition_matrix:
        print("Unknown Emotion State")
        return

    next_state = random.choices(
        list(transition_matrix[current].keys()),
        weights=transition_matrix[current].values()
    )[0]

    print("Predicted Next Emotional State:", next_state)

