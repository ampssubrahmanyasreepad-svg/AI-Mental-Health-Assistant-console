# ==========================================================
# BFS SEARCH
# ==========================================================

def bfs_recovery(start):

    print("\n===== BFS Emotional Recovery =====")

    queue = deque([(start, [])])

    visited = set()

    while queue:

        state, path = queue.popleft()

        if state not in visited:

            visited.add(state)

            print("Visited:", state)

            if state == "Calm":
                return path + ["Calm"]

            for action in emotion_graph.get(state, []):
                queue.append(("Calm", path + [action]))

    return None

# ==========================================================
# DFS SEARCH
# ==========================================================

def dfs_recovery(state, visited=None, path=None):

    if visited is None:
        visited = set()

    if path is None:
        path = []

    print("Visited:", state)

    if state == "Calm":
        return path + ["Calm"]

    visited.add(state)

    for action in emotion_graph.get(state, []):

        result = dfs_recovery("Calm", visited, path + [action])

        if result:
            return result

    return None

# ==========================================================
# A* SEARCH
# ==========================================================

def heuristic(action):

    return recovery_cost[action]

def astar_recovery(start):

    print("\n===== A* Emotional Recovery =====")

    pq = []

    visited = set()

    for action in emotion_graph[start]:

        cost = heuristic(action)

        heapq.heappush(pq, (cost, action))

    while pq:

        cost, action = heapq.heappop(pq)

        print(f"Selected Action: {action}")
        print(f"Heuristic Cost: {cost}")

        if action not in visited:

            visited.add(action)

            return ["Start", action, "Calm"]

    return None

# ==========================================================
# CSP WELLNESS CHECKER
# ==========================================================

def wellness_csp():

    print("\n==============================")
    print(" WELLNESS CONSTRAINT CHECKER ")
    print("==============================")

    sleep = int(input("Sleep Hours: "))
    stress = int(input("Stress Level (1-100): "))
    screen = int(input("Screen Time Hours: "))

    valid = True

    if sleep < 6:
        print("Constraint Failed -> Low Sleep")
        valid = False

    if stress > 70:
        print("Constraint Failed -> High Stress")
        valid = False

    if screen > 6:
        print("Constraint Failed -> Excess Screen Time")
        valid = False

    if valid:
        print("Wellness Constraints Satisfied")
    else:
        print("Mental Wellness Imbalance Detected")

