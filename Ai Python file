@app.route("/results")
def results():
    profile = session.get("profile")
    answers = session.get("answers")

    if not profile or not answers or len(answers) < len(QUESTIONS):
        return redirect(url_for("index"))

    # Compute category raw scores
    stress_val = sum(int(answers.get(str(i), 0)) for i in [0, 1, 2])     # Max score = 12
    anxiety_val = sum(int(answers.get(str(i), 0)) for i in [3, 4])       # Max score = 8
    depression_val = sum(int(answers.get(str(i), 0)) for i in [5, 6])    # Max score = 8
    sleep_val = sum(int(answers.get(str(i), 0)) for i in [7, 8])         # Max score = 8
    social_val = sum(int(answers.get(str(i), 0)) for i in [9, 10])       # Max score = 8

    # Calculate Percentages
    stress_pct = round((stress_val / 12.0) * 100)
    anxiety_pct = round((anxiety_val / 8.0) * 100)
    depression_pct = round((depression_val / 8.0) * 100)
    sleep_pct = round((sleep_val / 8.0) * 100)
    social_pct = round((social_val / 8.0) * 100)

    category_scores = {
        "Stress": stress_pct,
        "Anxiety": anxiety_pct,
        "Depression": depression_pct,
        "Sleep": sleep_pct,
        "Social": social_pct
    }

    avg_risk = (stress_pct + anxiety_pct + depression_pct + sleep_pct + social_pct) / 5.0
    wellness_score = round(100.0 - avg_risk)

    # 1. Profile information
    age = profile["age"]
    age_cat = get_age_category(age)
    name = profile["name"]
    gender = profile["gender"]
    situation = profile["situation"]
    mood = MOOD_EMOJIS.get(profile["mood"], profile["mood"])

    # 2. Bayesian prediction calculation
    priors = {
        "Healthy": 0.35,
        "Mild Stress": 0.30,
        "Moderate Stress": 0.20,
        "High Stress": 0.10,
        "Burnout Risk": 0.05
    }
    centers = {
        "Healthy": 10,
        "Mild Stress": 30,
        "Moderate Stress": 50,
        "High Stress": 70,
        "Burnout Risk": 90
    }
    emojis = {
        "Healthy": "🟢",
        "Mild Stress": "🟡",
        "Moderate Stress": "🟠",
        "High Stress": "🔴",
        "Burnout Risk": "⚫"
    }
    badge_colors = {
        "Healthy": "badge-green",
        "Mild Stress": "badge-yellow",
        "Moderate Stress": "badge-orange",
        "High Stress": "badge-red",
        "Burnout Risk": "badge-indigo"
    }

    sigma = 15.0
    posteriors_unnorm = {}
    total_unnorm = 0.0
    for state, prior in priors.items():
        center = centers[state]
        # Gaussian Likelihood
        likelihood = math.exp(-((avg_risk - center) ** 2) / (2 * (sigma ** 2)))
        unnorm = prior * likelihood
        posteriors_unnorm[state] = unnorm
        total_unnorm += unnorm

    normalized = {}
    for state, unnorm in posteriors_unnorm.items():
        normalized[state] = round((unnorm / total_unnorm) * 100, 1) if total_unnorm > 0 else 0.0

    # Enforce sum to be exactly 100.0%
    diff = round(100.0 - sum(normalized.values()), 1)
    if diff != 0.0:
        max_state = max(normalized, key=normalized.get)
        normalized[max_state] = round(normalized[max_state] + diff, 1)

    today_state = max(normalized, key=normalized.get)

    # 3. Explainable AI Card (reasons)
