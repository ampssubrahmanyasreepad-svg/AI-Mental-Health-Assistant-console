    else:
        options = [
            (0, "Never"),
            (1, "Rarely"),
            (2, "Sometimes"),
            (3, "Often"),
            (4, "Always")
        ]

    # Generate radio choices HTML
    radio_choices_html = ""
    for score, label in options:
        is_checked = "checked" if saved_answer is not None and saved_answer == score else ""
        radio_choices_html += f"""
        <label class="radio-card">
            <input type="radio" name="answer" value="{score}" {is_checked}>
            <div class="radio-circle"></div>
            <span class="radio-text">{label}</span>
        </label>
