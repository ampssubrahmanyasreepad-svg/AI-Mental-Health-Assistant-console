@app.route("/quiz/<int:qnum>", methods=["GET", "POST"])
def quiz(qnum):
    # Ensure profile exists
    if "profile" not in session:
        return redirect(url_for("intake"))

    if qnum < 0 or qnum >= len(QUESTIONS):
        return redirect(url_for("intake"))

    question = QUESTIONS[qnum]
    qnum_str = str(qnum)
    error = ""

    # Fetch answer from session if already exists
    saved_answer = session.get("answers", {}).get(qnum_str)

    if request.method == "POST":
        answer_str = request.form.get("answer")
        if answer_str is None:
            error = "Please select an option to continue."
        else:
            answers = session.get("answers", {})
            answers[qnum_str] = int(answer_str)
            session["answers"] = answers
            session.modified = True
            
            if qnum == len(QUESTIONS) - 1:
                return redirect(url_for("results"))
            else:
                return redirect(url_for("quiz", qnum=qnum + 1))

    # Calculate overall progress percent
    progress_pct = (qnum / len(QUESTIONS)) * 100

    # Handle positive/negative labels order based on question reverse-scoring
    if question["reverse"]:
        options = [
            (0, "Always"),
            (1, "Often"),
            (2, "Sometimes"),
            (3, "Rarely"),
            (4, "Never")
